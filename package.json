{
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.11",
  "license": "MIT",
  "workspaces": [
    "filesize-diff"
  ],
  "scripts": {
    "check": "bun run lint && bun run knip && bun run typecheck",
    "check:artifacts": "bun run build:actions && ! (git status --porcelain | grep '^.M' | grep dist)",
    "build:actions": "bun -F '*' build",
    "knip": "knip -n",
    "lint": "eslint .",
    "prepare": "bunx simple-git-hooks",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "devDependencies": {
    "@kevinmarrec/eslint-config": "^1.15.0",
    "@kevinmarrec/tsconfig": "^1.15.0",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "4.1.2",
    "eslint": "^10.2.0",
    "knip": "^6.3.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2"
  },
  "simple-git-hooks": {
    "pre-commit": "echo 'Pre-commit checks' && bun run check:artifacts"
  }
}
